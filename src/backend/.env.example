# ── Database ─────────────────────────────────────────
# Neon (recommended free Postgres with pgvector):
#   1. Create project at neon.tech
#   2. Copy connection string, replace postgresql:// with postgresql+asyncpg://
# Supabase (alternative, includes auth + DB):
#   1. Go to Project Settings → Database → Connection string
#   2. Use Session mode (port 5432), append ?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL_SYNC=postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ── Redis ────────────────────────────────────────────
# Upstash (free Redis):
#   1. Create database at upstash.com → Redis → Create
#   2. Copy the UPSTASH_REDIS_REST_URL or set up the redis:// URL
#      REDIS_URL=redis://default:password@endpoint.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# ── Environment ──────────────────────────────────────
ENVIRONMENT=production

# ── CORS ─────────────────────────────────────────────
# JSON array of allowed frontend origins (Vercel deployment URL)
CORS_ORIGINS=["https://your-frontend.vercel.app"]

# ── Supabase Auth ────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── JWT ──────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── AI / LLM ─────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_PROVIDER=nvidia
LLM_MODEL=nvidia/nemotron-3-nano-30b-a3b

# ── External APIs ────────────────────────────────────
GOOGLE_MAPS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── DigiLocker ───────────────────────────────────────
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=

# ── PWA Push (Web Push) ─────────────────────────────
# Generate VAPID keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=admin@wander.app
